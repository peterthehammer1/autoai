# Auto Service Booking API - Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Server Configuration
PORT=3001
NODE_ENV=development

# Security
API_KEY=your-api-key
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Twilio (for SMS confirmations)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Public API URL used by Twilio as the statusCallback target for outbound SMS.
# Set to the deployed backend origin (e.g. https://autoai-backend.vercel.app).
# On Vercel, VERCEL_URL is used as a fallback if this is unset.
PUBLIC_API_URL=https://your-backend.vercel.app

# SMS test allowlist — comma-separated numbers (any format; non-digits stripped).
# When set, SMS sends to numbers NOT in this list are blocked and logged as status='blocked'.
# Intent: prevent accidental sends to real customers during demos / client testing.
# Leave unset in production.
# SMS_TEST_ALLOWLIST=+15612215911,+14165551234

# Nucleus AI (for webhook validation)
NUCLEUS_API_KEY=your-nucleus-api-key

# Vehicle Databases API (for VIN decode, maintenance schedules, recalls)
# Get your API key at https://vehicledatabases.com/portal/signup
VEHICLE_DATABASES_API_KEY=your-vehicle-databases-api-key

# Business Settings
TIMEZONE=America/Toronto
